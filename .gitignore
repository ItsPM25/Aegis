# ===== Aegis root .gitignore =====

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Node / frontend (command centre) ---
node_modules/
.next/
out/
build/
dist/
.vercel/

# --- Env & secrets (NEVER commit API keys) ---
.env
.env.*
!.env.example
*.pem

# --- Large data & model artifacts ---
# Keep the repo light — don't commit datasets or big weights.
# Commit small sample/mock files instead (see contracts/samples & shared/mock_data).
*/data/*
!*/data/.gitkeep
!*/data/README.md
*.csv
*.parquet
*.tif
*.zip
*.pt
*.pth
*.h5
*.pkl
*.joblib
*.onnx
*/models/*
!*/models/.gitkeep
# Runtime note captures from the counterfeit demo UI (per-scan artifacts).
*/output/captures/
# Fusion runtime artifacts (LLM-generated eval text, per-run reports) — regenerated on demand.
command-centre/fusion/output/
# Sonification audio from `fraud-graph spectral --sonify` — ~350KB each, regenerated on demand.
# The sonifier HTML reads output/spectral_data.json, which IS committed.
fraud-graph-ml/output/*.wav
fraud-graph-ml/output/arms_race*.png

# --- Personal learning notes & work log (local only, never commit) ---
learning.md
WORKLOG.md
BUG_REPORT.md

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
tsconfig.tsbuildinfo

# --- Evaluation artifacts the dashboard READS AT RUNTIME -------------------
# These are small JSON/CSV reports, not model weights. `*/models/*` and `*.csv`
# above were sweeping them up, so a deployment checkout had no metrics to serve:
# the Model Card rendered only its static header and Research Lab reported
# "Arms-race history not generated yet". Weights (.pkl/.pt/.joblib) stay ignored.
!*/models/train_report.json
!fraud-graph-ml/models/ring_eval_report.json
!fraud-graph-ml/models/elliptic_benchmark_report.json
!fraud-graph-ml/output/arms_race_history.csv
